# =============================================================================
# .gitignore — Big Data Lab
# =============================================================================

# Secrets — NEVER commit
.env

# Local Docker volume data (can be large; regenerated by docker-compose up)
namenode_data/
datanode_data/
postgres_data/

# Student data uploads (contain potentially sensitive datasets)
data/

# Python / Jupyter artefacts
__pycache__/
*.pyc
.ipynb_checkpoints/

# macOS artefacts
.DS_Store

# IntelliJ / VS Code
.idea/
.vscode/

# Leftover editor backup files
*~
*.bak
"docker-compose copy.yml"
