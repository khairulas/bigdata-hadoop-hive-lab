# Enforce LF line endings for all text files — prevents CRLF breaking bash inside Linux containers
*.sh        text eol=lf
*.sql       text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env*      text eol=lf
*.ini       text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.csv       text eol=lf

# Binary files — do not mangle line endings
*.jar       binary
*.docx      binary
*.png       binary
*.jpg       binary
*.pbix      binary
